rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Per-user data (history + profile) ──────────────────────────────────
    // Each signed-in user can only read and write their own document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Nested usage subcollection (if used in the future)
      match /usage/{key} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Legacy anonymous usage tracking ───────────────────────────────────
    // Kept for backwards compatibility with unauthenticated visitors.
    match /usage/{usageId} {
      allow get: if true;
      allow create: if request.resource.data.keys().hasAll(['count', 'lastUpdate']) &&
                      request.resource.data.count == 1;
      allow update: if request.resource.data.keys().hasAll(['count', 'lastUpdate']) &&
                      request.resource.data.count == resource.data.count + 1;
    }

    // ── Demo usage tracking ─────────────────────────────────────────
    match /demo_usage/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Default deny everything else
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
